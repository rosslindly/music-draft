# Supabase — local dev values from `supabase status`
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # required for reset-db script

# Spotify OAuth
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173

# Apify (optional — for live listener count fetching)
VITE_APIFY_TOKEN=your-apify-token-here
